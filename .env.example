# 環境設定ファイルのテンプレート
# このファイルを .env にコピーして、プロジェクトに合わせて値を編集してください

# 実行環境 (development, production, test)
ENVIRONMENT=development

# Discord Bot トークン (https://discord.com/developers/applications)
DISCORD_TOKEN=

# エラーログ送信先の Discord チャンネル ID (未設定の場合は送信スキップ)
LOG_CHANNEL_ID=

# セッション終了時の結果送信先の Discord チャンネル ID (未設定の場合は送信スキップ)
RESULT_CHANNEL_ID=
